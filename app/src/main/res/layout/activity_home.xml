<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#12131C">

    <!-- Header Section -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/headerLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="24dp"
        android:paddingTop="40dp"
        android:paddingBottom="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/txtGreeting"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Khám phá hành trình mới cùng"
            android:textColor="#3B82F6"
            android:textSize="14sp"
            android:letterSpacing="0.05"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/txtTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="VCar Premium"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/txtGreeting" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Premium Search Bar -->
    <androidx.cardview.widget.CardView
        android:id="@+id/searchCard"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="8dp"
        app:cardBackgroundColor="#1B1C26"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:layout_constraintTop_toBottomOf="@id/headerLayout">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/ic_menu_search"
                app:tint="#8A8C9E"/>

            <EditText
                android:id="@+id/edtSearch"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginStart="12dp"
                android:background="@android:color/transparent"
                android:hint="Tìm kiếm dòng xe yêu thích..."
                android:textColorHint="#5A5C70"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:maxLines="1"
                android:inputType="text"/>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <!-- Premium Promo Card -->
    <androidx.cardview.widget.CardView
        android:id="@+id/promoCard"
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="16dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="4dp"
        app:layout_constraintTop_toBottomOf="@id/searchCard">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_promo_gradient"
            android:padding="20dp">

            <!-- Banner details -->
            <TextView
                android:id="@+id/txtPromoTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SIÊU ƯU ĐÃI THÀNH VIÊN"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtPromoDesc"
                android:layout_width="220dp"
                android:layout_height="wrap_content"
                android:layout_below="@id/txtPromoTitle"
                android:layout_marginTop="6dp"
                android:text="Nhập mã VCAR30 nhận ngay giảm giá 30% cho lượt đặt xe tiếp theo!"
                android:textColor="#F3F4F6"
                android:textSize="12sp"
                android:lineSpacingExtra="2dp" />

            <ImageView
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:src="@drawable/ic_vcar_logo"
                app:tint="#FFFFFF"
                android:alpha="0.25"/>

        </RelativeLayout>

    </androidx.cardview.widget.CardView>

    <!-- Horizontal Category Selector -->
    <HorizontalScrollView
        android:id="@+id/categoryScroll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:scrollbars="none"
        android:clipToPadding="false"
        android:paddingHorizontal="24dp"
        app:layout_constraintTop_toBottomOf="@id/promoCard">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingVertical="4dp">

            <!-- Chip 1: Tất cả -->
            <TextView
                android:id="@+id/chipAll"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tất cả"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold"
                android:paddingHorizontal="18dp"
                android:paddingVertical="8dp"
                android:background="@drawable/bg_chip_active"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginEnd="10dp"/>

            <!-- Chip 2: Xe điện -->
            <TextView
                android:id="@+id/chipElectric"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Xe điện"
                android:textColor="#8A8C9E"
                android:textSize="13sp"
                android:paddingHorizontal="18dp"
                android:paddingVertical="8dp"
                android:background="@drawable/bg_chip_inactive"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginEnd="10dp"/>

            <!-- Chip 3: Thể thao -->
            <TextView
                android:id="@+id/chipSport"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Thể thao"
                android:textColor="#8A8C9E"
                android:textSize="13sp"
                android:paddingHorizontal="18dp"
                android:paddingVertical="8dp"
                android:background="@drawable/bg_chip_inactive"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginEnd="10dp"/>

            <!-- Chip 4: Sedan -->
            <TextView
                android:id="@+id/chipSedan"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sedan"
                android:textColor="#8A8C9E"
                android:textSize="13sp"
                android:paddingHorizontal="18dp"
                android:paddingVertical="8dp"
                android:background="@drawable/bg_chip_inactive"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginEnd="10dp"/>

            <!-- Chip 5: SUV / MPV -->
            <TextView
                android:id="@+id/chipSuv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SUV / MPV"
                android:textColor="#8A8C9E"
                android:textSize="13sp"
                android:paddingHorizontal="18dp"
                android:paddingVertical="8dp"
                android:background="@drawable/bg_chip_inactive"
                android:clickable="true"
                android:focusable="true"/>

        </LinearLayout>
    </HorizontalScrollView>

    <!-- RecyclerView for Cars List -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvCars"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:clipToPadding="false"
        android:paddingTop="8dp"
        android:paddingBottom="16dp"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
        app:layout_constraintBottom_toTopOf="@id/bottomNav"
        app:layout_constraintTop_toBottomOf="@+id/categoryScroll"
        tools:listitem="@layout/item_car" />

    <!-- Bottom Navigation Bar -->
    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="#1B1C26"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Home Tab (Active) -->
        <LinearLayout
            android:id="@+id/navHome"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?android:attr/selectableItemBackground">

            <ImageView
                android:id="@+id/navHomeIcon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_home"
                app:tint="#2563EB"/>

            <TextView
                android:id="@+id/navHomeText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Trang chủ"
                android:textColor="#2563EB"
                android:textSize="11sp"
                android:textStyle="bold"/>

        </LinearLayout>

        <!-- History Tab -->
        <LinearLayout
            android:id="@+id/navHistory"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?android:attr/selectableItemBackground">

            <ImageView
                android:id="@+id/navHistoryIcon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_history"
                app:tint="#8A8C9E"/>

            <TextView
                android:id="@+id/navHistoryText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Lịch sử"
                android:textColor="#8A8C9E"
                android:textSize="11sp"/>

        </LinearLayout>

        <!-- Contact Tab -->
        <LinearLayout
            android:id="@+id/navContact"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?android:attr/selectableItemBackground">

            <ImageView
                android:id="@+id/navContactIcon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_phone"
                app:tint="#8A8C9E"/>

            <TextView
                android:id="@+id/navContactText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Liên hệ"
                android:textColor="#8A8C9E"
                android:textSize="11sp"/>

        </LinearLayout>

        <!-- Profile Tab -->
        <LinearLayout
            android:id="@+id/navProfile"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?android:attr/selectableItemBackground">

            <ImageView
                android:id="@+id/navProfileIcon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_user_profile"
                app:tint="#8A8C9E"/>

            <TextView
                android:id="@+id/navProfileText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Cá nhân"
                android:textColor="#8A8C9E"
                android:textSize="11sp"/>

        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>