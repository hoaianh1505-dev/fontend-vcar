<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?android:attr/selectableItemBackground"
    app:cardBackgroundColor="@android:color/transparent"
    app:cardElevation="0dp"
    app:cardMaxElevation="0dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_car_card"
        android:paddingBottom="16dp">

        <!-- Image Container (CardView for rounded clipping) -->
        <androidx.cardview.widget.CardView
            android:id="@+id/imgCardContainer"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:layout_margin="12dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#2E2F3E"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <ImageView
                    android:id="@+id/imgCar"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    tools:srcCompat="@tools:sample/backgrounds/scenic" />

                <!-- Availability Status Badge -->
                <TextView
                    android:id="@+id/txtStatusBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="top|end"
                    android:layout_margin="12dp"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="6dp"
                    android:text="Còn xe"
                    android:textColor="#22C55E"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_badge_available" />

            </FrameLayout>

        </androidx.cardview.widget.CardView>

        <!-- Brand Tag -->
        <TextView
            android:id="@+id/txtBrand"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="12dp"
            android:textColor="#3B82F6"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/imgCardContainer"
            tools:text="TESLA" />

        <!-- Car Model Name -->
        <TextView
            android:id="@+id/txtName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="4dp"
            android:layout_marginEnd="16dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/txtBrand"
            tools:text="Tesla Model Y" />

        <!-- Location Info -->

        <!-- Specifications Tags Grid -->
        <TextView
            android:id="@+id/txtLocation"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:drawablePadding="6dp"
            android:textColor="#8A8C9E"
            android:textSize="13sp"
            app:drawableStartCompat="@android:drawable/ic_menu_mylocation"
            app:drawableTint="#5A5C70"
            app:layout_constraintStart_toStartOf="@+id/txtName"
            app:layout_constraintTop_toBottomOf="@+id/txtName"
            tools:text="Hà Nội, Việt Nam" />

        <LinearLayout
            android:id="@+id/layoutSpecs"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal"
            app:layout_constraintStart_toStartOf="@+id/txtName"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/txtLocation">

            <!-- Spec 1: Year -->
            <TextView
                android:id="@+id/txtSpecYear"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:background="#1AFFFFFF"
                android:paddingHorizontal="10dp"
                android:paddingVertical="5dp"
                android:textColor="#C0C2D3"
                android:textSize="11sp"
                android:textStyle="bold"
                tools:text="Đời 2024" />

            <!-- Spec 2: Transmission -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:background="#1AFFFFFF"
                android:paddingHorizontal="10dp"
                android:paddingVertical="5dp"
                android:textColor="#C0C2D3"
                android:textSize="11sp"
                android:textStyle="bold"
                android:text="Tự động" />

            <!-- Spec 3: Fuel -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="#1AFFFFFF"
                android:paddingHorizontal="10dp"
                android:paddingVertical="5dp"
                android:textColor="#C0C2D3"
                android:textSize="11sp"
                android:textStyle="bold"
                android:text="Xăng" />

        </LinearLayout>

        <View
            android:id="@+id/divider"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#2E2F3E"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@+id/layoutSpecs"/>

        <!-- Bottom Price & Detail Info -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:paddingHorizontal="16dp"
            app:layout_constraintTop_toBottomOf="@+id/divider">

            <!-- Price -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="bottom"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent">

                <TextView
                    android:id="@+id/txtPrice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#009CBD"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    tools:text="$65" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:textColor="#8A8C9E"
                    android:textSize="13sp"
                    android:text="/ ngày" />

            </LinearLayout>

            <!-- Action Link / Detail Arrow -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Xem chi tiết →"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"/>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.cardview.widget.CardView>